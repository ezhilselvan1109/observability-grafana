{
  "title": "User Service",
  "uid": "user_service",
  "schemaVersion": 36,
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "User Registrations",
      "type": "stat",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "users_registered_total",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "axisPlacement": "auto"
          },
          "unit": "short"
        }
      }
    },
    {
      "id": 2,
      "title": "Login Requests",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{uri=\"/api/users/login\"}[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "axisPlacement": "auto"
          },
          "unit": "short"
        }
      }
    },
    {
      "id": 3,
      "title": "Authentication Failures",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{uri=\"/api/users/login\", status=\"401\"}[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "axisPlacement": "auto"
          },
          "unit": "short"
        }
      }
    },
    {
      "id": 4,
      "title": "Active DB Connections",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "hikaricp_connections_active{application=\"user-service\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "axisPlacement": "auto"
          },
          "unit": "short"
        }
      }
    }
  ]
}